{
    "workbench.tree.indent": 14,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.colorCustomizations": {
        "tree.indentGuidesStroke": "#A08070"
    },
    "workbench.editor.closeEmptyGroups": false,
    "workbench.activityBar.orientation": "vertical",
    "workbench.editor.pinnedTabsOnSeparateRow": true,
    "workbench.list.openMode": "doubleClick",
    "workbench.startupEditor": "welcomePage",
    "workbench.editor.empty.hint": "hidden",
    "workbench.editorAssociations": {
        "*.svg": "default"
    },
    "workbench.editor.enablePreview": false,
    "workbench.colorTheme": "Best Themes - Rose Noctis",
    "workbench.iconTheme": "material-icon-theme",

    "window.zoomLevel": 0.55,
    "window.titleBarStyle": "custom",
    "window.customMenuBarAltFocus": false,
    "window.enableMenuBarMnemonics": false,
    "window.menuBarVisibility": "visible",
    "window.openFilesInNewWindow": "off",
    "window.openFoldersInNewWindow": "off",
    "window.density.editorTabHeight": "default",
    "window.commandCenter": true,

    "editor.fontLigatures": true,
    // ================
    // "editor.fontFamily": "Rec Mono Casual",
    // "editor.fontSize": 14,
    // // "editor.lineHeight": 1.35,
    // "editor.lineHeight": 1.6,
    // "editor.letterSpacing": -0.5,
    // ================
    "editor.fontFamily": "Maple Mono",
    "editor.lineHeight": 1.45,
    "editor.fontSize": 13,
    // "editor.letterSpacing": -0.25,
    // ================
    // "editor.fontFamily": "Google Sans Code",
    // "editor.lineHeight": 1.5,
    // "editor.fontSize": 13,
    // "editor.letterSpacing": -0.25,
    // ================
    "editor.occurrencesHighlight": "off",
    "editor.selectionHighlight": false,
    "editor.dragAndDrop": false,
    "explorer.enableDragAndDrop": false,
    "editor.cursorStyle": "line-thin",
    "editor.formatOnSave": false,
    "editor.matchBrackets": "near",
    "editor.wordWrap": "on",
    "editor.wrappingIndent": "deepIndent",
    "editor.snippetSuggestions": "inline",
    "editor.pasteAs.enabled": false,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "never",
        "source.fixAll": "never"
    },
    "editor.renderLineHighlight": "gutter",
    "editor.smoothScrolling": true,
    "editor.minimap.enabled": false,
    "editor.linkedEditing": true,
    "editor.stickyScroll.enabled": false,
    "editor.inlineSuggest.edits.showCollapsed": true,
    "editor.accessibilitySupport": "off",
    "editor.inlayHints.enabled": "offUnlessPressed",
    "editor.trimAutoWhitespace": false,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": [
                    "comment",
                    "punctuation.definition.comment",
                    "support.class.component",
                    "variable.parameter",
                    "keyword.control",
                    "keyword.control.import",
                    "keyword.control.export",
                    "keyword.control.from",
                    "entity.other.attribute-name",
                    "variable",
                    "variable.other.property",
                    "variable.other.readwrite",
                    "variable.other.enummember",
                    "variable.other.constant",
                    "variable.other.object.property",
                    "variable.language",
                    "storage.modifier",
                    "support.type.primitive",
                    "keyword.operator",
                    "meta.attribute.id entity.other.attribute-name",
                    "support.type.vendored",
                    "comment.block.documentation punctuation.definition.block.tag",
                    "comment.block.documentation storage.type.class",
                    "comment.line",
                    "comment.line.number-sign.python",
                    "meta.import keyword.control",
                    "support.type.builtin",
                    "source.rust meta.attribute.rust",
                    "markup.list",
                    "fenced_code.block.language",
                    "storage.type.function",
                    "storage.type",
                    "storage.type.type",
                    "entity.name.function",
                    "entity.name.type.class",
                    "support.class.dart",
                    "comment.line.double-slash",
                    "keyword.control.import.python",
                    "keyword.control.flow.python",
                    "entity.other.attribute-name.tsx",
                    "support.function",
                    "entity.other.inherited-class",
                    "source.go storage.type",
                    "constant.other.placeholder"
                ],
                "settings": {
                    "fontStyle": ""
                }
            },
            {
                "scope": "meta.tag meta.jsx.children",
                "settings": {
                    "foreground": "#d2d2d2"
                }
            }
        ]
    },
    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            "property.static:typescript": {
                "underline": false
            },
            "method.static:typescript": {
                "underline": false
            },
            "function.declaration": {
                "bold": false
            },
            "method": {
                "italic": false
            }
        }
    },

    "explorer.autoReveal": false,
    "explorer.compactFolders": false,
    "explorer.confirmDelete": false,

    "files.trimTrailingWhitespace": true,
    "files.trimTrailingWhitespaceInRegexAndStrings": false,
    "files.associations": {
        "*.css": "tailwindcss",
        "*.kts": "kotlinscript",
        "*.conf": "shellscript"
    },
    "files.exclude": {
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        "**/node_modules": true,
        "**/postgres-data": true
    },

    "security.promptForLocalFileProtocolHandling": false,

    "settingsSync.keybindingsPerPlatform": false,

    "git.openRepositoryInParentFolders": "never",

    "diffEditor.ignoreTrimWhitespace": false,

    "github.copilot.enable": {
        "*": true,
        "plaintext": false,
        "markdown": false,
        "scminput": false,
        "python": false,
        "sql": false
    },

    "cursor.cpp.disabledLanguages": [
        "markdown",
        "plaintext",
        "dart"
    ],

    /* ========================================= */
    /* =========== Language Specific =========== */
    /* ========================================= */

    // ------- C++ -------
    "C_Cpp.default.cppStandard": "c++17",
    "[cpp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },

    // ------- Python -------
    "python.analysis.diagnosticSeverityOverrides": {
        "reportMissingImports": "none",
        "reportUndefinedVariable": "none",
        "reportMissingModuleSource": "none"
    },
    "notebook.output.textLineLimit": 50,

    // ------- Dart -------
    "dart.flutterCreateAndroidLanguage": "java",
    "dart.debugExternalPackageLibraries": false,
    "dart.debugSdkLibraries": false,
    "dart.closingLabels": false,

    // --------- Ruby -------
    "[ruby]": {
        "editor.defaultFormatter": "rubocop.vscode-rubocop"
    },

    // ------- Golang -------
    "[go]": {
        "editor.formatOnSave": false,
    },

    // ------- JSON -------
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },

    // ------- HTML -------
    "html.autoClosingTags": false,
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // ------- JavaScript -------
    "javascript.updateImportsOnFileMove.enabled": "never",
    "javascript.autoClosingTags": false,
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // ------- TypeScript -------
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "typescript.autoClosingTags": false,
    "typescript.preferences.jsxAttributeCompletionStyle": "none",
    "typescript.updateImportsOnFileMove.enabled": "never",
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // ------- CSS -------
    "css.lint.unknownAtRules": "ignore",
    "scss.lint.unknownAtRules": "ignore",
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[scss]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[postcss]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // ------- Svelte -------
    "svelte.enable-ts-plugin": true,
    "[svelte]": {
        "editor.defaultFormatter": "svelte.svelte-vscode"
    },

    /* ========================================== */
    /* =========== Extension Specific =========== */
    /* ========================================== */

    // ------- Rest Client -------
    "rest-client.previewOption": "full",
    "rest-client.defaultHeaders": {
        "User-Agent": "vscode-restclient",
        "Content-Type": "application/json",
        "Accept": "application/json",
        "Accept-Language": "en-US,en;q=0.5",
        "Accept-Encoding": "gzip, deflate, br, zstd"
    },

    // ------- Eyecons -------
    "eyecons.folderColor": "orange",
    "eyecons.hidesExplorerArrows": true,
    "eyecons.theme": "github-dark",

    // ------- Pop Icons -------
    "pop-icon-theme.folders.color": "#ff7043",

    // ------- Helium Icons -------
    "helium-icon-theme.folders.color": "#90a4ae",

    // ------- Bazel -------
    // TODO: what about this ?
    "bazel.executable": "/nix/store/y1zdzring1mji64iy0njvb7fz62khz80-ktmr-final-environment/bin/bazel",

    // ------- Symbol Icons -------
    "symbols.hidesExplorerArrows": false,
    "svg.preview.mode": "img",

    // ------- Markdown -------
    "mdmath.delimiters": "dollars",
    "mdmath.theme": "publication",
    "mdmath.style": "/home/radium/hwlab/analysis/global.css",
    "markdown.preview.scrollEditorWithPreview": false,
    "markdown.preview.scrollPreviewWithEditor": false,
    "markdown-pdf.displayHeaderFooter": false,
    "markdown-pdf.highlightStyle": "lightfair.css",

    // ==========================
}