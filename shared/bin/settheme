#!/usr/bin/env bash
#
# settheme — one command to reskin the whole terminal environment.
#
# Design (see dotfiles README "Theming"):
#   * kitty is the single source of the 16 ANSI colors. This script copies the
#     chosen palette from kitty/themes/<name>.conf into the globinclude'd
#     kitty/theme.conf and live-reloads every running window over its socket.
#     (This used to be driven by `tinty`; the palettes are now vendored in-repo,
#     so tinty is no longer a dependency.)
#   * fzf, starship and gitui are all configured to FOLLOW those ANSI colors, so
#     they need no per-theme handling here — they just track kitty automatically.
#   * nvim, yazi and bat keep their own native theme ports; this script repoints
#     them so they match the chosen scheme. (bat followed the ANSI palette too,
#     but base16's comment colour is unreadably dim, so it's a native port now.)
#   * delta is intentionally NOT managed — it keeps its own mantis-shrimp theme.
#
# Registry columns:  name | kitty-conf | nvim-colorscheme | yazi-flavor | bat-theme
#
# The yazi-flavor column normally matches the theme, but a few themes have no
# dedicated yazi flavor (yazi's flavor ecosystem is thin, esp. for light themes);
# those borrow the closest available flavor of the same lightness (noted inline).
#
set -euo pipefail

STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/settheme"
STATE_FILE="$STATE_DIR/current"
KITTY_THEMES_DIR="$HOME/.config/kitty/themes"
KITTY_THEME_FILE="$HOME/.config/kitty/theme.conf"
NVIM_CS_FILE="$HOME/.config/nvim/lua/config/colorscheme.lua"
YAZI_THEME_FILE="$HOME/.config/yazi/theme.toml"
BAT_CONFIG_FILE="$HOME/.config/bat/config"

# The theme registry. One `theme` line per entry — copy a line and edit the five
# fields to add one. Spacing between columns is arbitrary (shell word-splitting),
# so alignment is purely cosmetic; just quote any field containing a space (only
# the bat theme names do). Field meanings:
#   name  : friendly name you pass to `settheme`
#   kitty : palette file in kitty/themes/ (the <name>.conf basename, minus .conf)
#   nvim  : :colorscheme name         yazi : flavor dir name (minus .yazi)
#   bat   : `bat --list-themes` name (keyed by the .tmTheme filename)
registry() {
  theme() { printf '%s|%s|%s|%s|%s\n' "$1" "$2" "$3" "$4" "$5"; }

  #     name                   kitty conf             nvim colorscheme       yazi flavor            bat theme
  theme catppuccin-mocha       catppuccin-mocha       catppuccin-mocha       catppuccin-mocha       "Catppuccin Mocha"
  theme tokyo-night            tokyo-night            tokyonight-night       tokyo-night            "tokyonight_night"
  theme gruvbox                gruvbox                gruvbox                gruvbox-dark           "gruvbox-dark"
  theme rose-pine              rose-pine              rose-pine              rose-pine              "rose-pine"
  theme nord                   nord                   nord                   nord                   "Nord"
  theme kanagawa               kanagawa               kanagawa               kanagawa               "Kanagawa"
  theme dracula                dracula                dracula                dracula                "Dracula"
  theme onedark                onedark                onedark                onedark                "TwoDark"
  theme catppuccin-frappe      catppuccin-frappe      catppuccin-frappe      catppuccin-frappe      "Catppuccin Frappe"
  theme catppuccin-macchiato   catppuccin-macchiato   catppuccin-macchiato   catppuccin-macchiato   "Catppuccin Macchiato"
  theme catppuccin-latte       catppuccin-latte       catppuccin-latte       catppuccin-latte       "Catppuccin Latte"
  theme tokyo-night-day        tokyo-night-day        tokyonight-day         tokyonight-day         "tokyonight_day"
  theme rose-pine-dawn         rose-pine-dawn         rose-pine-dawn         catppuccin-latte       "rose-pine-dawn"
}

current_theme() { [ -f "$STATE_FILE" ] && cat "$STATE_FILE" || true; }

lookup() { registry | awk -F'|' -v n="$1" '$1==n{print; f=1} END{exit !f}'; }

list_themes() {
  local cur; cur="$(current_theme)"
  echo "Available themes:"
  registry | while IFS='|' read -r name _; do
    if [ "$name" = "$cur" ]; then echo "  * $name (current)"; else echo "    $name"; fi
  done
}

# Machine-readable list of names, for shell completion.
names() { registry | cut -d'|' -f1; }

# Render a compact color preview of a theme's palette straight from its vendored
# kitty conf, using 24-bit escapes with the theme's OWN hex values — so it shows
# the true colors regardless of the terminal's current palette. Used as the fzf
# `--preview` in `--pick`.
swatch() {
  local name="${1:-}" conf="$KITTY_THEMES_DIR/${1:-}.conf"
  if [ -z "$name" ] || [ ! -f "$conf" ]; then echo "  (no palette: $name)"; return 0; fi

  # hex (#rrggbb) -> a 2-cell block painted in that color
  _blk() { local h=${1#\#}; printf '\033[48;2;%d;%d;%dm  \033[0m' \
    "$((16#${h:0:2}))" "$((16#${h:2:2}))" "$((16#${h:4:2}))"; }
  _val() { awk -v k="$1" '$1==k{print $2; exit}' "$conf"; }

  local i hex
  if [ "$name" = "$(current_theme)" ]; then printf '\n  %s (current)\n\n' "$name"
  else printf '\n  %s\n\n' "$name"; fi
  printf '  '; for i in 0 1 2 3 4 5 6 7;        do _blk "$(_val "color$i")"; done; printf '\n  '
  for i in 8 9 10 11 12 13 14 15;               do _blk "$(_val "color$i")"; done; printf '\n\n'
  local bg fg; bg=$(_val background); fg=$(_val foreground); bg=${bg#\#}; fg=${fg#\#}
  printf '  \033[48;2;%d;%d;%dm\033[38;2;%d;%d;%dm  The quick brown fox jumps  \033[0m\n' \
    "$((16#${bg:0:2}))" "$((16#${bg:2:2}))" "$((16#${bg:4:2}))" \
    "$((16#${fg:0:2}))" "$((16#${fg:2:2}))" "$((16#${fg:4:2}))"
}

# Interactive picker with LIVE preview. As the selection moves, the whole
# terminal repaints to that palette (transient `set-colors -a`, no disk write);
# Enter commits the full reskin via apply_theme, Esc restores the palette that
# was active on entry. Designed to be launched in a kitty overlay (see keymaps).
pick() {
  command -v fzf >/dev/null 2>&1 || { echo "settheme: fzf is required for --pick" >&2; exit 1; }
  local orig list sel
  orig="$(current_theme)"
  # Put the current theme first so opening the picker previews it (no jarring
  # color jump), and it's pre-selected.
  if [ -n "$orig" ] && names | grep -qx "$orig"; then
    list="$(printf '%s\n' "$orig"; names | grep -vx "$orig")"
  else
    list="$(names)"
  fi

  sel="$(printf '%s\n' "$list" | fzf \
      --prompt='theme  ' \
      --layout=reverse --height=100% --cycle --no-multi \
      --preview='settheme --swatch {}' \
      --preview-window='down,7,border-top' \
      --bind="focus:execute-silent(kitten @ set-colors -a $KITTY_THEMES_DIR/{}.conf >/dev/null 2>&1)" \
      --header='↑↓ live preview · enter: apply · esc: cancel')" || sel=""

  if [ -n "$sel" ]; then
    echo
    apply_theme "$sel"
  else
    # Aborted: undo the transient preview by re-applying the entry palette.
    if [ -n "$orig" ] && [ -f "$KITTY_THEMES_DIR/$orig.conf" ]; then
      kitten @ set-colors -a "$KITTY_THEMES_DIR/$orig.conf" >/dev/null 2>&1 || true
    fi
    echo "settheme: cancelled${orig:+ — restored '$orig'}."
  fi
}

usage() {
  cat <<EOF
usage: settheme [<name>]        apply a theme across all tools
       settheme --pick          interactive picker with live preview (fzf)
       settheme --list          list available themes (current marked with *)
       settheme --current       print the active theme name
       settheme --names         print theme names, one per line (for completion)

EOF
  list_themes
}

apply_theme() {
  local name="$1" row _ kitty_conf nvim_cs yazi_flavor bat_theme
  if ! row="$(lookup "$name")"; then
    echo "settheme: unknown theme '$name'" >&2
    echo >&2
    list_themes >&2
    exit 1
  fi
  IFS='|' read -r _ kitty_conf nvim_cs yazi_flavor bat_theme <<<"$row"

  # 1) kitty palette: copy the vendored conf into the globinclude'd theme.conf,
  #    then live-reload every running window over its socket. `kitten @ set-colors`
  #    with no --to auto-targets kitty via $KITTY_LISTEN_ON; the `|| true` keeps
  #    this working when run outside kitty (e.g. plain SSH). The ANSI-following
  #    tools (fzf/starship/gitui) inherit the new palette for free.
  local kitty_src="$KITTY_THEMES_DIR/$kitty_conf.conf"
  if [ ! -f "$kitty_src" ]; then
    echo "settheme: kitty palette not found: $kitty_src" >&2
    exit 1
  fi
  echo "› kitty  : $kitty_conf"
  mkdir -p "$(dirname "$KITTY_THEME_FILE")"
  cp -f "$kitty_src" "$KITTY_THEME_FILE"
  kitten @ set-colors -a -c "$KITTY_THEME_FILE" >/dev/null 2>&1 || true

  # 2) nvim: write the generated colorscheme module (picked up on next launch;
  #    running instances need :colorscheme or a restart).
  echo "› nvim   : colorscheme $nvim_cs"
  mkdir -p "$(dirname "$NVIM_CS_FILE")"
  printf 'return "%s"\n' "$nvim_cs" >"$NVIM_CS_FILE"

  # 3) yazi: repoint the dark flavor (open a new yazi to pick it up).
  if [ -f "$YAZI_THEME_FILE" ]; then
    echo "› yazi   : flavor $yazi_flavor"
    local tmp="${YAZI_THEME_FILE}.settheme.tmp"
    awk -v f="$yazi_flavor" '
      /^\[flavor\]/ { inflavor = 1 }
      inflavor && /^[[:space:]]*dark[[:space:]]*=/ {
        sub(/=.*/, "= \"" f "\""); inflavor = 0
      }
      { print }
    ' "$YAZI_THEME_FILE" >"$tmp" && mv "$tmp" "$YAZI_THEME_FILE"
  fi

  # 4) bat: write the theme into its config (read on every invocation, so all
  #    new `bat` runs pick it up immediately — even in already-open shells).
  #    The .tmTheme files ship in dotfiles/shared/bat/themes; `bat cache --build`
  #    (run once on setup) registers them by filename.
  echo "› bat    : theme $bat_theme"
  mkdir -p "$(dirname "$BAT_CONFIG_FILE")"
  printf -- '--theme="%s"\n' "$bat_theme" >"$BAT_CONFIG_FILE"

  mkdir -p "$STATE_DIR"
  printf '%s\n' "$name" >"$STATE_FILE"
  echo
  echo "✓ theme set to '$name'."
  echo "  kitty + bat updated live. Open a new nvim / yazi / gitui to pick it up."
}

case "${1:-}" in
  ""|-h|--help)  usage ;;
  -p|--pick)     pick ;;
  --swatch)      swatch "${2:-}" ;;
  -l|--list)     list_themes ;;
  --current)     current_theme ;;
  --names)       names ;;
  -*)            echo "settheme: unknown option '$1'" >&2; echo >&2; usage >&2; exit 1 ;;
  *)             apply_theme "$1" ;;
esac
