                    "keyword.control.flow.python",
                    "entity.other.attribute-name.tsx",
                    "support.function",
                    "entity.other.inherited-class",
                    "source.go storage.type",
                    "constant.other.placeholder",
                    "variable.other.field",
                    "constant.other.table-name",
                    "string.quoted.docstring.multi",
                    "storage.type.built-in",
                    "storage.type.modifier",
                    "keyword.function.go",
                    "storage.type.function.kotlin",
                    "entity.name.type.kotlin",
                    "comment.block.documentation",
                    "variable.language.self",
                    "variable.parameter.function",
                    "comment",
                    "comment.block",
                    "comment.block.documentation",
                    "comment.line",
                    "constant",
                    "constant.character",
                    "constant.language",
                    "constant.numeric",
                    "constant.other",
                    "constant.regexp",
                    "constant.rgb-value",
                    "constant.other.color",
                    "constant.other.placeholder",
                    "constant.other.table-name",
                    "emphasis",
                    "entity",
                    "entity.name",
                    "entity.name.class",
                    "entity.name.function",
                    "entity.name.method",
                    "entity.name.namespace",
                    "entity.name.section",
                    "entity.name.tag",
                    "entity.name.type",
                    "entity.name.type.class",
                    "entity.name.type.enum",
                    "entity.name.type.interface",
                    "entity.name.type.kotlin",
                    "entity.name.type.module",
                    "entity.name.type.namespace",
                    "entity.name.type.struct",
                    "entity.other",
                    "entity.other.attribute-name",
                    "entity.other.attribute-name.class",
                    "entity.other.attribute-name.id",
                    "entity.other.attribute-name.tsx",
                    "entity.other.inherited-class",
                    "invalid",
                    "invalid.deprecated",
                    "invalid.illegal",
                    "keyword",
                    "keyword.control",
                    "keyword.control.export",
                    "keyword.control.flow",
                    "keyword.control.from",
                    "keyword.control.import",
                    "keyword.control.import.python",
                    "keyword.control.flow.python",
                    "keyword.function.go",
                    "keyword.operator",
                    "keyword.operator.arithmetic",
                    "keyword.operator.assignment",
                    "keyword.operator.bitwise",
                    "keyword.operator.comparison",
                    "keyword.operator.expression",
                    "keyword.operator.logical",
                    "keyword.operator.new",
                    "keyword.operator.other",
                    "keyword.operator.relational",
                    "keyword.operator.ternary",
                    "keyword.operator.type",
                    "keyword.other",
                    "keyword.other.unit",
                    "markup",
                    "markup.bold",
                    "markup.changed",
                    "markup.deleted",
                    "markup.heading",
                    "markup.inline.raw",
                    "markup.inserted",
                    "markup.italic",
                    "markup.list",
                    "markup.list.numbered",
                    "markup.list.unnumbered",
                    "markup.other",
                    "markup.punctuation.list.beginning",
                    "markup.punctuation.quote.beginning",
                    "markup.quote",
                    "markup.raw",
                    "markup.raw.block",
                    "markup.raw.inline",
                    "markup.underline",
                    "markup.underline.link",
                    "meta",
                    "meta.attribute",
                    "meta.brace",
                    "meta.delimiter",
                    "meta.embedded",
                    "meta.function",
                    "meta.function-call",
                    "meta.import",
                    "meta.object-literal.key",
                    "meta.preprocessor",
                    "meta.return-type",
                    "meta.selector",
                    "meta.separator",
                    "meta.structure",
                    "meta.tag",
                    "meta.template.expression",
                    "meta.type.annotation",
                    "meta.type.parameters",
                    "fenced_code.block.language",
                    "punctuation",
                    "punctuation.accessor",
                    "punctuation.definition",
                    "punctuation.definition.block.tag",
                    "punctuation.definition.comment",
                    "punctuation.definition.parameters",
                    "punctuation.definition.string",
                    "punctuation.definition.tag",
                    "punctuation.definition.template-expression",
                    "punctuation.section",
                    "punctuation.separator",
                    "punctuation.terminator",
                    "source",
                    "storage",
                    "storage.modifier",
                    "storage.type",
                    "storage.type.built-in",
                    "storage.type.class",
                    "storage.type.enum",
                    "storage.type.function",
                    "storage.type.function.kotlin",
                    "storage.type.generic",
                    "storage.type.interface",
                    "storage.type.modifier",
                    "storage.type.namespace",
                    "storage.type.numeric",
                    "storage.type.object",
                    "storage.type.primitive",
                    "storage.type.property",
                    "storage.type.string",
                    "storage.type.token",
                    "storage.type.type",
                    "string",
                    "string.interpolated",
                    "string.other",
                    "string.quoted",
                    "string.quoted.docstring.multi",
                    "string.quoted.double",
                    "string.quoted.single",
                    "string.regexp",
                    "string.template",
                    "string.unquoted",
                    "strong",
                    "support",
                    "support.class",
                    "support.class.component",
                    "support.class.dart",
                    "support.constant",
                    "support.function",
                    "support.function.magic",
                    "support.other",
                    "support.other.namespace",
                    "support.other.variable",
                    "support.type",
                    "support.type.builtin",
                    "support.type.primitive",
                    "support.type.property-name",
                    "support.type.vendored",
                    "support.variable",
                    "token.debug-token",
                    "token.error-token",
                    "token.info-token",
                    "token.warn-token",
                    "variable",
                    "variable.language",
                    "variable.language.self",
                    "variable.language.super",
                    "variable.language.this",
                    "variable.other",
                    "variable.other.constant",
                    "variable.other.enummember",
                    "variable.other.field",
                    "variable.other.member",
                    "variable.other.object",
                    "variable.other.object.property",
                    "variable.other.property",
                    "variable.other.readwrite",
                    "variable.parameter",
                    "variable.parameter.function",
                    "constant.language.boolean.true",
                    "constant.language.boolean.false",
                    "constant.language.null"
                ],
                "settings": {
                    "fontStyle": ""
                }
            },
            {
                "scope": "meta.tag meta.jsx.children",
                "settings": {
                    "foreground": "#d2d2d2"
                }
            }
        ]
    },
    "editor.semanticTokenColorCustomizations": {
        "enabled": true,
        "rules": {
            "*.declaration": {
                "italic": false
            },
            "*.definition": {
                "italic": false
            },
            "*.abstract": {
                "italic": false
            },
            "*.async": {
                "italic": false
            },
            "*.readonly": {
                "italic": false
            },
            "*.static": {
                "italic": false
            },
            "*.deprecated": {
                "italic": false
            },
            "class": {
                "italic": false
            },
            "class.declaration": {
                "italic": false
            },
            "comment": {
                "italic": false
            },
            "decorator": {
                "italic": false
            },
            "enum": {
                "italic": false
            },
            "enumMember": {
                "italic": false
            },
            "event": {
                "italic": false
            },
            "function": {
                "italic": false
            },
            "function.declaration": {
                "italic": false
            },
            "interface": {
                "italic": false
            },
            "keyword": {
                "italic": false
            },
            "label": {
                "italic": false
            },
            "macro": {
                "italic": false
            },
            "method": {
                "italic": false
            },
            "method.declaration": {
                "italic": false
            },
            "modifier": {
                "italic": false
            },
            "namespace": {
                "italic": false
            },
            "number": {
                "italic": false
            },
            "operator": {
                "italic": false
            },
            "parameter": {
                "italic": false
            },
            "property": {
                "italic": false
            },
            "property.declaration": {
                "italic": false
            },
            "property.readonly": {
                "italic": false
            },
            "regexp": {
                "italic": false
            },
            "selfKeyword": {
                "italic": false
            },
            "string": {
                "italic": false
            },
            "struct": {
                "italic": false
            },
            "type": {
                "italic": false
            },
            "typeAlias": {
                "italic": false
            },
            "typeParameter": {
                "italic": false
            },
            "variable": {
                "italic": false
            },
            "variable.declaration": {
                "italic": false
            },
            "variable.readonly": {
                "italic": false
            },
            "property.static:typescript": {
                "underline": false
            },
            "method.static:typescript": {
                "underline": false
            },
            "function.declaration": {
                "bold": false
            },
            "method": {
                "italic": false
            }
        }
    },
    "workbench.iconTheme": "material-icon-theme",
    "workbench.colorCustomizations": {
        "tree.indentGuidesStroke": "#A08070"
    },
    "editor.matchBrackets": "never",
    "editor.occurrencesHighlight": "off",
    "editor.selectionHighlight": false,
    /* ============================ */
    /* ========== Claude ========== */
    /* ============================ */
    "claudeCode.preferredLocation": "panel",
    /* ================================= */
    /* ============ Copilot ============ */
    /* ================================= */
    "chat.tools.terminal.autoApprove": {
        "cd": true,
        "echo": true,
        "ls": true,
        "dir": true,
        "pwd": true,
        "cat": true,
        "head": true,
        "tail": true,
        "findstr": true,
        "wc": true,
        "tr": true,
        "cut": true,
        "cmp": true,
        "which": true,
        "basename": true,
        "dirname": true,
        "realpath": true,
        "readlink": true,
        "stat": true,
        "file": true,
        "od": true,
        "du": true,
        "df": true,
        "sleep": true,
        "nl": true,
        "grep": true,
        "git add": true,
        "git reset": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+status\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+log\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+show\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+diff\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+ls-files\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+grep\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+branch\\b/": true,
        "/^git(\\s+(-C\\s+\\S+|--no-pager))*\\s+branch\\b.*\\s-(d|D|m|M|-delete|-force)\\b/": false,
        "column": true,
        "/^column\\b.*\\s-c\\s+[0-9]{4,}/": false,
        "date": true,
        "/^date\\b.*\\s(-s|--set)\\b/": false,
        "find": true,
        "/^find\\b.*\\s-(delete|exec|execdir|fprint|fprintf|fls|ok|okdir)\\b/": false,
        "rg": true,
        "/^rg\\b.*\\s(--pre|--hostname-bin)\\b/": false,
        "sed": true,
        "/^sed\\b.*\\s(-[a-zA-Z]*(e|f)[a-zA-Z]*|--expression|--file)\\b/": false,
        "/^sed\\b.*s\\/.*\\/.*\\/[ew]/": false,
        "/^sed\\b.*;W/": false,
        "sort": true,
        "/^sort\\b.*\\s-(o|S)\\b/": false,
        "tree": true,
        "/^tree\\b.*\\s-o\\b/": false,
        "/^xxd$/": true,
        "/^xxd\\b(\\s+-\\S+)*\\s+[^-\\s]\\S*$/": true,
        "rm": false,
        "rmdir": false,
        "ri": false,
        "rd": false,
        "erase": false,
        "dd": false,
        "kill": false,
        "ps": false,
        "top": false,
        "spps": false,
        "curl": false,
        "wget": false,
        "irm": false,
        "iwr": false,
        "chmod": false,
        "chown": false,
        "sp": false,
        "jq": false,
        "xargs": false,
        "eval": false,
        "iex": false,
        "kubectl --context=local": true,
        "git rev-list": true,
        "gh pr create": true,
        "git rev-parse": true,
        "git worktree": true
    },
    "chat.viewSessions.orientation": "stacked",
    "chat.agent.maxRequests": 500,
    "chat.useHooks": true,
    "chat.hookFilesLocations": {
        "~/.copilot/hooks": true
    },
    "github.copilot.nextEditSuggestions.enabled": false,
    /* ============================ */
    /* =========== Misc =========== */
    /* ============================ */
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false,
        "python": false,
        "sql": false,
        "coffeescript": false,
        "jsonc": false,
        "ruby": false,
        "go": false
    },
    "cursor.cpp.disabledLanguages": [
        "plaintext",
        "dart",
        "cpp",
        "untitled",
        "csv",
        "jsonc"
    ],
    "window.customMenuBarAltFocus": false,
    "window.enableMenuBarMnemonics": false,
    "window.menuBarVisibility": "visible",
    /* ========================================= */
    /* =========== Language Specific =========== */
    /* ========================================= */
    // ------- C++ -------
    "C_Cpp.default.cppStandard": "c++17",
    "[cpp]": {
        "editor.defaultFormatter": "xaver.clang-format"
    },
    // ------- Python -------
    "python.analysis.diagnosticSeverityOverrides": {
        "reportMissingImports": "none",
        "reportUndefinedVariable": "none",
        "reportMissingModuleSource": "none"
    },
    "notebook.output.textLineLimit": 50,
    "notebook.cellToolbarLocation": {
        "default": "right",
        "jupyter-notebook": "right"
    },
    "python.defaultInterpreterPath": "/Users/qateef.ahmad/.pyenv/versions/3.11.14/bin/python",
    "python.terminal.activateEnvironment": false,
    // ------- Dart -------
    "dart.flutterCreateAndroidLanguage": "java",
    "dart.debugExternalPackageLibraries": false,
    "dart.debugSdkLibraries": false,
    "dart.closingLabels": false,
    // --------- Ruby -------
    "[ruby]": {
        "editor.defaultFormatter": "rubocop.vscode-rubocop"
    },
    // ------- Golang -------
    "[go]": {
        "editor.formatOnSave": false,
    },
    // ------- kotlin -------
    "kotlin.languageServer.enabled": false,
    "kotlin.debugAdapter.enabled": false,
    // ------- Java -------
    "[java]": {
        "editor.defaultFormatter": "redhat.java"
    },
    // ------- JSON -------
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.detectIndentation": true
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.detectIndentation": true
    },
    // ------- HTML -------
    "html.autoClosingTags": false,
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    // ------- JavaScript -------
    "javascript.updateImportsOnFileMove.enabled": "never",
    "javascript.autoClosingTags": false,
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    // ------- TypeScript -------
    "typescript.enablePromptUseWorkspaceTsdk": true,
    "typescript.autoClosingTags": false,
    "typescript.preferences.jsxAttributeCompletionStyle": "none",
    "typescript.updateImportsOnFileMove.enabled": "never",
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    // ------- CSS -------
    "css.lint.unknownAtRules": "ignore",
    "scss.lint.unknownAtRules": "ignore",
    "[css]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[scss]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[postcss]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    // ------- Svelte -------
    "svelte.enable-ts-plugin": true,
    "[svelte]": {
        "editor.defaultFormatter": "svelte.svelte-vscode"
    },
    // ------- Ruby -------
    "svelte.enable-ts-plugin": true,
    "[ruby]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.detectIndentation": true
    },
    /* ========================================== */
    /* =========== Extension Specific =========== */
    /* ========================================== */
    // ------- Rest Client -------
    "rest-client.previewOption": "full",
    "rest-client.defaultHeaders": {
        "User-Agent": "vscode-restclient",
        "Content-Type": "application/json",
        "Accept": "application/json",
        "Accept-Language": "en-US,en;q=0.5",
        "Accept-Encoding": "gzip, deflate, br, zstd"
    },
    // ------- Eyecons -------
    "eyecons.folderColor": "orange",
    "eyecons.hidesExplorerArrows": true,
    "eyecons.theme": "github-dark",
    // ------- Pop Icons -------
    "pop-icon-theme.folders.color": "#ff7043",
    // ------- Helium Icons -------
    "helium-icon-theme.folders.color": "#90a4ae",
    // ------- Bazel -------
    // TODO: what about this ?
    "bazel.executable": "/nix/store/y1zdzring1mji64iy0njvb7fz62khz80-ktmr-final-environment/bin/bazel",
    // ------- Symbol Icons -------
    "symbols.hidesExplorerArrows": false,
    "svg.preview.mode": "img",
    // ------- Markdown -------
    "mdmath.delimiters": "dollars",
    "mdmath.theme": "publication",
    "mdmath.style": "/home/radium/hwlab/analysis/global.css",
    "markdown.preview.scrollEditorWithPreview": false,
    "markdown.preview.scrollPreviewWithEditor": false,
    "markdown-pdf.displayHeaderFooter": false,
    "markdown-pdf.highlightStyle": "lightfair.css",
    // ------- Settings Sync -------
    "settingsSync.keybindingsPerPlatform": false,
    // ------- CSV (A UI csv Viewer) -------
    "csv.enabled": false,
    // ------- GitLens -------
    "gitlens.currentLine.enabled": false,
    "gitlens.codeLens.authors.enabled": false,
    "gitlens.codeLens.recentChange.enabled": false,
    // ------- RedHat (for Java) -------
    "redhat.telemetry.enabled": false,
    "window.autoDetectColorScheme": false,
    "claudeCode.enableNewConversationShortcut": true,
    "workbench.colorTheme": "Perpetuity Light",
    "extensions.installCooldownHours": 72,
    "gitTreeCompare.diffMode": "full",
    "terraform.mcp.server.enable": true,
}