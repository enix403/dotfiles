{
  "name": "enix-vscode-tools",
  "displayName": "Enix VSCode Tools",
  "description": "Custom VS Code tools for enix workflows",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "enix-vscode-tools.joinLinesWithSeparator",
        "title": "enix: join lines with separator"
      },
      {
        "command": "enix-vscode-tools.splitSelectionIntoLines",
        "title": "enix: split selection into lines"
      },
      {
        "command": "enix-vscode-tools.wrapLines",
        "title": "enix: wrap lines"
      },
      {
        "command": "enix-vscode-tools.appendToLines",
        "title": "enix: append to lines"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.95.0",
    "@types/node": "^22.x",
    "@typescript-eslint/eslint-plugin": "^8.x",
    "@typescript-eslint/parser": "^8.x",
    "eslint": "^9.x",
    "typescript": "^5.x"
  }
}
