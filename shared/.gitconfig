[user]
	name = enix403
	email = fog.code000@gmail.com

[alias]
  br = branch
  st = status --short
  stt = status
  stu = status --short --untracked=no
  unadd = restore --staged
  # list tracked but ignored local files
  # lowercase letters -> --assume-unchanged'd
  # S -> --skip-worktree'd
  ll = "!git ls-files -v | grep --color=always '^[hmrckusS]'"
  # list ignored files
  li = status --ignored --short
  co = checkout
  cm = commit
  cp = cherry-pick
  rs = reset
  sw = switch
  swc = switch -c
  ss = stash
  tg = tag
  df = diff
  dfc = diff --cached
  dfn = diff --name-only
  dfcn = diff --cached --name-only
  mr = merge
  lgg = log --decorate --oneline --graph --color --date=short
  lg = lgg --max-count=25
  ps = push
  pl = pull
  bl = blame
  rb = rebase
  rp = rev-parse
  ft = fetch
  wt = worktree
  ui = update-index
  uia = update-index --assume-unchanged
  uina = update-index --no-assume-unchanged
  uis = update-index --skip-worktree
  uins = update-index --no-skip-worktree
  ax = annex
	ib = !git branch --sort=-committerdate | sed \"s/^[ *]*//\" | fzf --height 30% --layout=reverse --border --info=inline | xargs git checkout
	ibd = !git branch --sort=-committerdate | sed \"s/^[ *]*//\" | fzf --height 40% --layout=reverse --multi --bind \"space:toggle+down\" --border --header \"SPACE to select branches to DELETE\" | xargs -r git branch -d
	ia = "!git status --short | perl -ne 'next if /^. /; my ($s, $w) = split //, substr($_, 0, 2); $s = \"\\e[32m$s\\e[0m\" if $s =~ /[^ ?]/; $s = \"\\e[31m$s\\e[0m\" if $s eq \"?\"; $w = \"\\e[31m$w\\e[0m\" if $w =~ /[^ ]/; print $s . $w . substr($_, 2)' | fzf --ansi --height 85% --layout=reverse --multi --bind \"space:toggle+down\" --border --header \"SPACE to choose, ENTER to stage\" --preview-window \"right:70%\" --preview \"git diff -- {2..} | delta --paging=never --width=\\$FZF_PREVIEW_COLUMNS | grep . || git diff --no-index /dev/null {2..} | delta --paging=never --width=\\$FZF_PREVIEW_COLUMNS\" | ansifilter | cut -c 4- | tr \"\\n\" \"\\0\" | xargs -0 -r git add"
  is = "!gitui"

[pager]
	branch = false
	stash = false

[init]
	defaultBranch = main

[diff]
  colorMoved = default

[push]
	autoSetupRemote = true

[credential]
  helper = cache --timeout 259200 # 72 hours / 3 days
  helper = "!f() { \
    if [ \"$(uname)\" = \"Darwin\" ]; then \
        git credential-osxkeychain $@; \
    else \
        git credential-libsecret $@; \
    fi; \
  }; f"
	helper = oauth # use "oauth -device" if you are running e.g over ssh and cannot open browser

# ================
# Config for Delta
# ================

[core]
  pager = delta
  longpaths = true

[interactive]
  diffFilter = delta --color-only

[merge]
  conflictstyle = zdiff3

[include]
  path = ~/dotfiles/shared/delta/themes.gitconfig

[delta]
  # `term-ansi` (defined below) draws everything from the terminal's 16 ANSI
  # colors, so delta follows whatever palette `settheme` sets on kitty.
  features = term-ansi

  # use n and N to move between diff sections
  navigate = true
  line-numbers = true
  side-by-side = true

  hyperlinks = true
  hyperlinks-file-link-format = "vscode://file/{path}:{line}"

  # Tab size
  tabs = 4

# Palette-following delta theme. Colors are ANSI indices 0-15, which map onto
# the active terminal palette (0 black, 1 red, 2 green, 3 yellow, 4 blue,
# 5 magenta, 6 cyan, 7 white, 8-15 the bright variants). `base16` syntax theme
# highlights code from the same 16 colors. Nothing here is theme-specific.
[delta "term-ansi"]
  syntax-theme = base16
  minus-style = 1
  minus-emph-style = syntax 9
  plus-style = 2
  plus-emph-style = syntax 10
  line-numbers-minus-style = 1
  line-numbers-plus-style = 2
  line-numbers-zero-style = 8
  line-numbers-left-style = 8
  line-numbers-right-style = 8
  hunk-header-style = syntax bold
  hunk-header-decoration-style = 8 box
  file-style = 12 bold
  file-decoration-style = 12 ul
  blame-palette = 0 8

# ====================
# END Config for Delta
# ====================

[color]
	ui = auto

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[include]
	path = ~/.gitconfig.local
